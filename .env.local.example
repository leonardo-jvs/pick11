# Copie este arquivo para .env.local (na raiz do projeto) e preencha com os
# valores do seu projeto Supabase: Project Settings -> API.

# URL do projeto (Project Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave pública anônima (Project Settings -> API -> Project API keys -> anon public)
# É segura para expor no navegador — o acesso real é controlado pelas
# políticas de Row Level Security (RLS) definidas nas migrations.
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_AQUI
